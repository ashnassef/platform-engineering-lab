    shape "${1:-}" "${2:-}" "${3:-}"
    ;;
  build)
    shift || true
    build "${1:-normal}"
    ;;
  deploy)
    deploy
    ;;
  undeploy)
    undeploy
    ;;
  smoke)
    smoke
    ;;
  view)
    view
    ;;
  expose)
    expose
    ;;
  status)
    shift || true
    status "${1:-short}"
    ;;
  diagnose)
    diagnose
    ;;
  scale)
    shift || true
    scale "${1:-}" "${2:-}"
    ;;
  drill)
    shift || true
    drill "${1:-status}"
    ;;
  repair)
    repair
    ;;
  destroy)
    destroy
    ;;
  *)
    usage
    exit 1
    ;;
esac
