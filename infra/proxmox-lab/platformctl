#!/usr/bin/env bash
set -euo pipefail

LAB_DIR="/root/terraform/proxmox-lab"
APP_DIR="/root/platform-engineering-lab"
BACKUP_DIR="/mnt/temp/platform-demo/platform-lab-backup-2026-05-31"

STATE_DIR="${LAB_DIR}/.platform"
STATE_FILE="${STATE_DIR}/state.json"

PROXMOX_NODE="${PROXMOX_NODE:-dev1}"
TEMPLATE_VMID="${TEMPLATE_VMID:-100}"
LAB_BRIDGE="${LAB_BRIDGE:-vmbr1}"
LAB_SUBNET="${LAB_SUBNET:-10.0.0.0/24}"

SSH_KNOWN_HOSTS="/root/.ssh/proxmox-lab-known_hosts"
QUEUE_NAME="events:queue"

CONTROL_IP=""
SSH_USER="dev1"
WORKER_IPS=()

VERIFY_FAILED=0
DIAGNOSE_FAILED=0

cd "$LAB_DIR"

usage() {
  cat <<USAGE
Usage:
  platformctl verify
  platformctl capacity
  platformctl shape check --workers <count>
  platformctl build [--resume|--force]
  platformctl deploy
  platformctl undeploy
  platformctl smoke
  platformctl status [full]
  platformctl diagnose
  platformctl repair
  platformctl view
  platformctl expose
  platformctl scale workers <replicas>
  platformctl drill {status|smoke|kill-api|kill-worker|kill-redis|backlog|idempotency|redis-persistence|drain-node|all}
  platformctl destroy

Typical controlled demo flow:
  platformctl verify
  platformctl capacity
  platformctl destroy
  platformctl status
  platformctl build
  platformctl deploy
  platformctl status
  platformctl smoke
  platformctl scale workers 3
  platformctl drill idempotency
platformctl drill drain-node
  platformctl drill all

Command meanings:
  verify      Check whether this host is ready to run/build the lab.
  capacity    Show host, Proxmox, Terraform, and Kubernetes capacity.
  shape      Validate a requested lab shape without provisioning it.
  status      Show what is currently built/running.
  diagnose    Investigate why something is unhealthy.
  repair      Try safe recovery steps.
  scale       Scale the app worker deployment.
  drain-node  Drain one worker node and prove pod rescheduling.
USAGE
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

timestamp() {
  date -Is
}

check_ok() {
  printf '\033[32m☑\033[0m %s\n' "$1"
}

check_no() {
  printf '\033[31m☐\033[0m %s\n' "$1"
}

check_warn() {
  printf '\033[33m☐\033[0m %s\n' "$1"
}

verify_ok() {
  check_ok "$1"
}

verify_no() {
  check_no "$1"
  VERIFY_FAILED=1
}

verify_warn() {
  check_warn "$1"
}

diagnose_ok() {
  check_ok "$1"
}

diagnose_no() {
  check_no "$1"
  DIAGNOSE_FAILED=1
}

diagnose_warn() {
  check_warn "$1"
}

state_init() {
  mkdir -p "$STATE_DIR"

  if [ ! -f "$STATE_FILE" ]; then
    jq -n \
      --arg updated_at "$(timestamp)" \
      '{
        status: "new",
        stage: "none",
        last_success: "",
        last_failure: "",
        message: "",
        updated_at: $updated_at,
        control_ip: "",
        worker_ips: []
      }' > "$STATE_FILE"
  fi
}

state_update() {
  local stage="$1"
  local status="$2"
  local message="${3:-}"

  state_init

  local old_last_success=""
  local old_last_failure=""
  local control_ip=""
  local worker_ips_json="[]"

  old_last_success="$(jq -r '.last_success // ""' "$STATE_FILE" 2>/dev/null || true)"
  old_last_failure="$(jq -r '.last_failure // ""' "$STATE_FILE" 2>/dev/null || true)"

  control_ip="$(terraform output -raw control_ip 2>/dev/null || true)"
  worker_ips_json="$(terraform output -json worker_ips 2>/dev/null || printf '[]')"

  if ! printf '%s' "$worker_ips_json" | jq empty >/dev/null 2>&1; then
    worker_ips_json="[]"
  fi

  local last_success="$old_last_success"
  local last_failure="$old_last_failure"

  if [ "$status" = "success" ]; then
    last_success="$stage"
    last_failure=""
  fi

  if [ "$status" = "failed" ]; then
    last_failure="$stage"
  fi

  jq -n \
    --arg status "$status" \
    --arg stage "$stage" \
    --arg last_success "$last_success" \
    --arg last_failure "$last_failure" \
    --arg message "$message" \
    --arg updated_at "$(timestamp)" \
    --arg control_ip "$control_ip" \
    --argjson worker_ips "$worker_ips_json" \
    '{
      status: $status,
      stage: $stage,
      last_success: $last_success,
      last_failure: $last_failure,
      message: $message,
      updated_at: $updated_at,
      control_ip: $control_ip,
      worker_ips: $worker_ips
    }' > "${STATE_FILE}.tmp"

  mv "${STATE_FILE}.tmp" "$STATE_FILE"
}

state_show() {
  state_init
  jq . "$STATE_FILE"
}

run_phase() {
  local phase="$1"
  shift

  echo
  echo "== ${phase} =="

  state_update "$phase" "running" ""

  set +e
  "$@"
  local rc="$?"
  set -e

  if [ "$rc" -eq 0 ]; then
    state_update "$phase" "success" ""
    return 0
  fi

  state_update "$phase" "failed" "exit code ${rc}"

  echo
  echo "Build failed at: ${phase}"
  echo "Current state file: ${STATE_FILE}"
  echo
  echo "Suggested next actions:"
  echo "  platformctl status full"
  echo "  platformctl diagnose"
  echo "  platformctl build --resume"
  echo "  platformctl repair"
  echo "  platformctl destroy"
  echo

  return "$rc"
}

require_root() {
  [ "$(id -u)" = "0" ] || die "Run this as root on the Proxmox host."
}

require_cmds() {
  for cmd in terraform kubectl jq curl ssh scp ss awk grep sed timeout ip sysctl free df nproc; do
    command -v "$cmd" >/dev/null 2>&1 || die "Missing required command: $cmd"
  done
}

require_file() {
  [ -f "$1" ] || die "Missing file: $1"
}

require_dir() {
  [ -d "$1" ] || die "Missing directory: $1"
}

require_lab_files() {
  require_file "$LAB_DIR/main.tf"
  require_file "$LAB_DIR/bootstrap-k3s.sh"
  require_file "$LAB_DIR/deploy-platform.sh"
  require_file "$LAB_DIR/drill-platform.sh"
  require_file "$LAB_DIR/view-platform.sh"
}

require_app_files() {
  require_dir "$APP_DIR"
  require_file "$APP_DIR/k8s/redis.yaml"
  require_file "$APP_DIR/k8s/api.yaml"
  require_file "$APP_DIR/k8s/worker.yaml"
  require_file "$APP_DIR/k8s/monitoring.yaml"
  require_file "$APP_DIR/k8s/ingress.yaml"
  require_file "$APP_DIR/observability/prometheus/prometheus.yml"
  require_file "$APP_DIR/observability/grafana/provisioning/datasources/prometheus.yml"
  require_file "$APP_DIR/observability/grafana/provisioning/dashboards/dashboards.yml"
  require_file "$APP_DIR/observability/grafana/dashboards/platform-lab.json"
}

require_image_backups() {
  require_file "$BACKUP_DIR/platform-engineering-lab-api.tar"
  require_file "$BACKUP_DIR/platform-engineering-lab-worker.tar"
}

require_kubeconfig() {
  require_file "/root/.kube/config"
}

terraform_has_lab_vms() {
  terraform state list 2>/dev/null | grep -q '^proxmox_virtual_environment_vm\.lab'
}

cluster_reachable() {
  [ -f /root/.kube/config ] || return 1
  kubectl cluster-info --request-timeout=3s >/dev/null 2>&1
}

require_cluster() {
  cluster_reachable || die "Kubernetes is not reachable. Run: platformctl build"
}

require_nodes_ready() {
  require_cluster

  local not_ready
  not_ready="$(kubectl get nodes --no-headers 2>/dev/null | awk '$2 != "Ready" {print $1}' || true)"

  [ -z "$not_ready" ] || die "Some Kubernetes nodes are not Ready: $not_ready"
}

require_deployment() {
  require_cluster
  kubectl get deployment "$1" >/dev/null 2>&1 || die "Missing deployment: $1. Run: platformctl deploy"
}

require_service() {
  require_cluster
  kubectl get service "$1" >/dev/null 2>&1 || die "Missing service: $1. Run: platformctl deploy"
}

require_platform() {
  require_nodes_ready

  for deploy in redis api worker prometheus grafana; do
    require_deployment "$deploy"
  done

  for svc in redis api worker prometheus grafana; do
    require_service "$svc"
  done
}

require_port_free() {
  local port="$1"

  if ss -ltn | awk '{print $4}' | grep -Eq "[:.]${port}$"; then
    die "Port ${port} is already in use. Stop the existing port-forward first."
  fi
}

confirm_exact() {
  local message="$1"

  echo "$message"
  read -r -p "Type yes to continue: " answer
  [ "$answer" = "yes" ] || die "Cancelled."
}

ssh_opts() {
  echo -o "UserKnownHostsFile=${SSH_KNOWN_HOSTS}" \
       -o "StrictHostKeyChecking=accept-new" \
       -o "ConnectTimeout=5"
}

install_lab_ssh_config() {
  mkdir -p /root/.ssh
  touch "$SSH_KNOWN_HOSTS"
  chmod 700 /root/.ssh
  chmod 600 "$SSH_KNOWN_HOSTS"

  if ! grep -q "Host 10.0.0.*" /root/.ssh/config 2>/dev/null; then
    cat >> /root/.ssh/config <<CONFIG

Host 10.0.0.*
    UserKnownHostsFile ${SSH_KNOWN_HOSTS}
    StrictHostKeyChecking accept-new
CONFIG
    chmod 600 /root/.ssh/config
  fi
}

load_outputs() {
  CONTROL_IP="$(terraform output -raw control_ip)"
  SSH_USER="$(terraform output -raw ssh_user 2>/dev/null || echo dev1)"

  mapfile -t WORKER_IPS < <(terraform output -json worker_ips | jq -r '.[]')

  [ -n "$CONTROL_IP" ] || die "Terraform output control_ip is empty."
  [ "${#WORKER_IPS[@]}" -gt 0 ] || die "Terraform output worker_ips is empty."
}

try_load_outputs() {
  CONTROL_IP="$(terraform output -raw control_ip 2>/dev/null || true)"
  SSH_USER="$(terraform output -raw ssh_user 2>/dev/null || echo dev1)"

  mapfile -t WORKER_IPS < <(terraform output -json worker_ips 2>/dev/null | jq -r '.[]' 2>/dev/null || true)
}

all_node_ips() {
  printf '%s\n' "$CONTROL_IP"
  printf '%s\n' "${WORKER_IPS[@]}"
}

clear_stale_ssh_keys() {
  install_lab_ssh_config

  for file in "$SSH_KNOWN_HOSTS" /root/.ssh/known_hosts; do
    touch "$file"

    ssh-keygen -f "$file" -R "$CONTROL_IP" >/dev/null 2>&1 || true

    for ip in "${WORKER_IPS[@]}"; do
      ssh-keygen -f "$file" -R "$ip" >/dev/null 2>&1 || true
    done
  done
}

wait_for_ssh_node() {
  local ip="$1"

  echo "Waiting for SSH: ${ip}"

  for i in $(seq 1 90); do
    if ssh $(ssh_opts) "${SSH_USER}@${ip}" "true" >/dev/null 2>&1; then
      echo "SSH ready: ${ip}"
      return 0
    fi

    sleep 5
  done

  die "SSH did not become ready on ${ip}"
}

wait_for_apt_node() {
  local ip="$1"

  echo "Waiting for cloud-init/apt: ${ip}"

  ssh $(ssh_opts) "${SSH_USER}@${ip}" 'bash -s' <<'REMOTE'
set -euo pipefail

if command -v cloud-init >/dev/null 2>&1; then
  timeout 420 sudo cloud-init status --wait >/dev/null 2>&1 || true
fi

for i in $(seq 1 120); do
  if sudo fuser /var/lib/dpkg/lock-frontend \
                /var/lib/dpkg/lock \
                /var/lib/apt/lists/lock \
                /var/cache/apt/archives/lock >/dev/null 2>&1; then
    echo "Waiting for apt lock..."
    sleep 5
  else
    break
  fi
done

if sudo fuser /var/lib/dpkg/lock-frontend \
              /var/lib/dpkg/lock \
              /var/lib/apt/lists/lock \
              /var/cache/apt/archives/lock >/dev/null 2>&1; then
  echo "Apt lock still held after timeout."
  exit 1
fi

sudo dpkg --configure -a

for i in $(seq 1 5); do
  if sudo apt-get update && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y curl; then
    exit 0
  fi

  echo "apt install failed; retrying..."
  sleep 10
done

exit 1
REMOTE

  echo "apt ready: ${ip}"
}

terraform_no_delete_plan() {
  local plan_file="/tmp/platformctl-build.tfplan"

  terraform init -input=false
  terraform validate

  terraform plan -input=false -out="$plan_file"

  local delete_count
  delete_count="$(terraform show -json "$plan_file" | jq '[.resource_changes[]? | select(.change.actions | index("delete"))] | length')"

  if [ "$delete_count" != "0" ]; then
    terraform show "$plan_file"
    die "Build plan includes delete/replace actions. Use 'platformctl destroy' explicitly first."
  fi

  terraform apply -input=false "$plan_file"
}

phase_preflight() {
  require_root
  require_cmds
  require_lab_files
  state_init
}

phase_terraform_apply() {
  terraform_no_delete_plan
}

phase_outputs() {
  load_outputs

  echo "Control: ${CONTROL_IP}"
  echo "Workers:"
  printf '  %s\n' "${WORKER_IPS[@]}"
}

phase_ssh_ready() {
  load_outputs
  clear_stale_ssh_keys

  while read -r ip; do
    wait_for_ssh_node "$ip"
  done < <(all_node_ips)
}

phase_apt_ready() {
  load_outputs

  while read -r ip; do
    wait_for_apt_node "$ip"
  done < <(all_node_ips)
}

phase_k3s_bootstrap() {
  ./bootstrap-k3s.sh
}

phase_nodes_ready() {
  require_kubeconfig
  kubectl cluster-info --request-timeout=10s >/dev/null

  kubectl wait --for=condition=Ready nodes --all --timeout=240s

  kubectl get nodes -o wide
}

deployment_exists() {
  kubectl --request-timeout=3s get deployment "$1" >/dev/null 2>&1
}

deployment_ready() {
  kubectl --request-timeout=3s get deployment "$1" -o json 2>/dev/null \
    | jq -e '((.spec.replicas // 0) >= 0) and ((.status.readyReplicas // 0) == (.spec.replicas // 0))' >/dev/null 2>&1
}

service_exists() {
  kubectl --request-timeout=3s get service "$1" >/dev/null 2>&1
}

all_deployments_ready() {
  local deploy

  for deploy in "$@"; do
    deployment_ready "$deploy" || return 1
  done
}

all_services_exist() {
  local svc

  for svc in "$@"; do
    service_exists "$svc" || return 1
  done
}

nodes_ready_line() {
  local total
  local ready

  total="$(kubectl --request-timeout=3s get nodes --no-headers 2>/dev/null | wc -l)"
  ready="$(kubectl --request-timeout=3s get nodes --no-headers 2>/dev/null | awk '$2 == "Ready" {count++} END {print count + 0}')"

  if [ "$total" -gt 0 ] && [ "$ready" -eq "$total" ]; then
    check_ok "Kubernetes nodes Ready: ${ready}/${total}"
  else
    check_no "Kubernetes nodes Ready: ${ready}/${total}"
  fi
}

redis_queue_line() {
  local len

  if ! deployment_exists redis; then
    check_no "Redis queue unavailable: deployment/redis missing"
    return 0
  fi

  len="$(kubectl exec deploy/redis -- redis-cli LLEN "$QUEUE_NAME" 2>/dev/null || echo unknown)"

  if [ "$len" = "0" ]; then
    check_ok "Redis queue length: 0"
  elif printf '%s' "$len" | grep -Eq '^[0-9]+$'; then
    check_warn "Redis queue length: ${len}"
  else
    check_no "Redis queue length unavailable"
  fi
}

api_health_line() {
  local port="18081"
  local pf_pid=""
  local health_ok="no"
  local ready_ok="no"

  if ! service_exists api; then
    check_no "API health unavailable: service/api missing"
    return 0
  fi

  if ss -ltn | awk '{print $4}' | grep -Eq "[:.]${port}$"; then
    check_warn "API health skipped: local port ${port} is busy"
    return 0
  fi

  kubectl port-forward service/api "${port}:8080" >/tmp/platformctl-api-check.log 2>&1 &
  pf_pid="$!"

  for _ in $(seq 1 30); do
    if curl -fsS "http://127.0.0.1:${port}/healthz" >/dev/null 2>&1; then
      health_ok="yes"
      break
    fi
    sleep 1
  done

  if curl -fsS "http://127.0.0.1:${port}/readyz" >/dev/null 2>&1; then
    ready_ok="yes"
  fi

  kill "$pf_pid" >/dev/null 2>&1 || true
  wait "$pf_pid" >/dev/null 2>&1 || true

  if [ "$health_ok" = "yes" ] && [ "$ready_ok" = "yes" ]; then
    check_ok "API health/readiness: ok/ready"
  else
    check_no "API health/readiness failed"
  fi
}

prometheus_targets_line() {
  local port="19091"
  local pf_pid=""
  local json=""
  local targets=""
  local unhealthy=""

  if ! service_exists prometheus; then
    check_no "Prometheus targets unavailable: service/prometheus missing"
    return 0
  fi

  if ss -ltn | awk '{print $4}' | grep -Eq "[:.]${port}$"; then
    check_warn "Prometheus targets skipped: local port ${port} is busy"
    return 0
  fi

  kubectl port-forward service/prometheus "${port}:9090" >/tmp/platformctl-prometheus-check.log 2>&1 &
  pf_pid="$!"

  for _ in $(seq 1 30); do
    if json="$(curl -fsS "http://127.0.0.1:${port}/api/v1/targets" 2>/dev/null)"; then
      break
    fi
    sleep 1
  done

  kill "$pf_pid" >/dev/null 2>&1 || true
  wait "$pf_pid" >/dev/null 2>&1 || true

  if [ -z "$json" ]; then
    check_no "Prometheus targets unavailable"
    return 0
  fi

  targets="$(printf '%s' "$json" | jq -r '[.data.activeTargets[]? | .labels.job] | unique | join(", ")')"
  unhealthy="$(printf '%s' "$json" | jq -r '[.data.activeTargets[]? | select(.health != "up") | .labels.job] | unique | join(", ")')"

  if [ -z "$targets" ]; then
    check_no "Prometheus targets missing"
  elif [ -z "$unhealthy" ]; then
    check_ok "Prometheus targets healthy: ${targets}"
  else
    check_no "Prometheus unhealthy targets: ${unhealthy}"
  fi
}


ingress_exists() {
  kubectl --request-timeout=3s get ingress platform-api >/dev/null 2>&1
}

ingress_controller_ready() {
  kubectl -n ingress-nginx --request-timeout=3s get deployment ingress-nginx-controller -o json 2>/dev/null \
    | jq -e '((.spec.replicas // 0) > 0) and ((.status.readyReplicas // 0) == (.spec.replicas // 0))' >/dev/null 2>&1
}

ingress_http_node_port() {
  kubectl -n ingress-nginx get service ingress-nginx-controller -o json 2>/dev/null \
    | jq -r '.spec.ports[]? | select(.name == "http") | .nodePort' \
    | head -1
}

api_ingress_line() {
  local control_ip=""
  local node_port=""

  if ! ingress_controller_ready; then
    check_no "Ingress controller unavailable"
    return 0
  fi

  if ! ingress_exists; then
    check_no "API ingress missing: platform-api"
    return 0
  fi

  control_ip="$(terraform output -raw control_ip 2>/dev/null || true)"
  node_port="$(ingress_http_node_port || true)"

  if [ -z "$control_ip" ] || [ -z "$node_port" ] || [ "$node_port" = "null" ]; then
    check_no "API ingress route unavailable"
    return 0
  fi

  if curl -fsS -H 'Host: platform.local' "http://${control_ip}:${node_port}/healthz" >/dev/null 2>&1; then
    check_ok "API ingress route: platform.local via ${control_ip}:${node_port}"
  else
    check_no "API ingress health check failed"
  fi
}

redis_persistence_line() {
  local appendonly=""

  if ! deployment_exists redis; then
    check_no "Redis persistence unavailable: deployment/redis missing"
    return 0
  fi

  if kubectl get pvc redis-data >/dev/null 2>&1; then
    check_ok "Redis PVC exists: redis-data"
  else
    check_no "Redis PVC missing: redis-data"
  fi

  appendonly="$(kubectl exec deploy/redis -- redis-cli CONFIG GET appendonly 2>/dev/null | awk 'NR == 2 {print $1}' || true)"

  if [ "$appendonly" = "yes" ]; then
    check_ok "Redis AOF persistence enabled"
  else
    check_no "Redis AOF persistence not enabled"
  fi
}

redis_persistence_drill() {
  require_platform

  local original_replicas
  local before_len
  local after_len
  local redis_pod

  original_replicas="$(kubectl get deployment worker -o jsonpath='{.spec.replicas}' 2>/dev/null || echo 1)"

  echo
  echo "== Redis persistence drill =="
  echo "Original worker replicas: ${original_replicas}"

  trap 'kubectl scale deployment/worker --replicas="'"$original_replicas"'" >/dev/null 2>&1 || true' INT TERM EXIT

  echo
  echo "Scaling workers to 0 so queue entries remain pending..."
  kubectl scale deployment/worker --replicas=0

  for _ in $(seq 1 30); do
    if [ "$(kubectl get pods -l app=worker --no-headers 2>/dev/null | wc -l)" = "0" ]; then
      break
    fi
    sleep 1
  done

  echo
  echo "Writing one pending event directly into Redis..."
  kubectl exec deploy/redis -- redis-cli DEL "$QUEUE_NAME" >/dev/null
  kubectl exec deploy/redis -- redis-cli RPUSH "$QUEUE_NAME" '{"id":"redis-persistence-drill","status":"queued","created_at":0}' >/dev/null

  before_len="$(kubectl exec deploy/redis -- redis-cli LLEN "$QUEUE_NAME")"
  echo "Queue length before Redis restart: ${before_len}"

  redis_pod="$(kubectl get pod -l app=redis -o jsonpath='{.items[0].metadata.name}')"

  echo
  echo "Deleting Redis pod: ${redis_pod}"
  kubectl delete pod "$redis_pod"
  kubectl rollout status deployment/redis --timeout=180s

  after_len="$(kubectl exec deploy/redis -- redis-cli LLEN "$QUEUE_NAME")"
  echo "Queue length after Redis restart: ${after_len}"

  if [ "$before_len" = "1" ] && [ "$after_len" = "1" ]; then
    check_ok "Redis queue survived pod restart"
  else
    check_no "Redis queue did not survive pod restart"
    return 1
  fi

  echo
  echo "Cleaning up drill queue and restoring workers..."
  kubectl exec deploy/redis -- redis-cli DEL "$QUEUE_NAME" >/dev/null
  kubectl scale deployment/worker --replicas="$original_replicas"

  if [ "$original_replicas" != "0" ]; then
    kubectl rollout status deployment/worker --timeout=180s
  fi

  trap - INT TERM EXIT

  check_ok "Redis persistence drill completed"
}
verify() {
  VERIFY_FAILED=0

  echo
  echo "== Host readiness =="

  if [ "$(id -u)" = "0" ]; then
    verify_ok "running as root"
  else
    verify_no "not running as root"
  fi

  for cmd in terraform kubectl jq curl ssh scp ss awk grep sed timeout ip sysctl free df nproc; do
    if command -v "$cmd" >/dev/null 2>&1; then
      verify_ok "${cmd} installed"
    else
      verify_no "${cmd} missing"
    fi
  done

  echo
  echo "== Proxmox readiness =="

  if command -v pvesh >/dev/null 2>&1 && pvesh get "/nodes/${PROXMOX_NODE}/status" >/dev/null 2>&1; then
    verify_ok "Proxmox API reachable for node ${PROXMOX_NODE}"
  else
    verify_no "Proxmox API not reachable for node ${PROXMOX_NODE}"
  fi

  if command -v qm >/dev/null 2>&1 && qm status "$TEMPLATE_VMID" >/dev/null 2>&1; then
    verify_ok "template VM ${TEMPLATE_VMID} exists"
  else
    verify_no "template VM ${TEMPLATE_VMID} missing"
  fi

  if ip link show "$LAB_BRIDGE" >/dev/null 2>&1; then
    verify_ok "lab bridge ${LAB_BRIDGE} exists"
  else
    verify_no "lab bridge ${LAB_BRIDGE} missing"
  fi

  if [ "$(sysctl -n net.ipv4.ip_forward 2>/dev/null || echo 0)" = "1" ]; then
    verify_ok "IPv4 forwarding enabled"
  else
    verify_no "IPv4 forwarding disabled"
  fi

  if iptables -t nat -S POSTROUTING 2>/dev/null | grep -q "$LAB_SUBNET"; then
    verify_ok "NAT rule exists for ${LAB_SUBNET}"
  else
    verify_warn "NAT rule for ${LAB_SUBNET} not found in iptables"
  fi

  echo
  echo "== Lab files =="

  for file in \
    "$LAB_DIR/main.tf" \
    "$LAB_DIR/bootstrap-k3s.sh" \
    "$LAB_DIR/deploy-platform.sh" \
    "$LAB_DIR/drill-platform.sh" \
    "$LAB_DIR/view-platform.sh" \
    "$LAB_DIR/platformctl"; do
    if [ -f "$file" ]; then
      verify_ok "$(basename "$file") exists"
    else
      verify_no "$(basename "$file") missing"
    fi
  done

  if terraform validate >/dev/null 2>&1; then
    verify_ok "Terraform configuration validates"
  else
    verify_no "Terraform configuration does not validate"
  fi

  echo
  echo "== App files =="

  if [ -d "$APP_DIR" ]; then
    verify_ok "app repo exists"
  else
    verify_no "app repo missing"
  fi

  for file in \
    "$APP_DIR/k8s/redis.yaml" \
    "$APP_DIR/k8s/api.yaml" \
    "$APP_DIR/k8s/worker.yaml" \
    "$APP_DIR/k8s/monitoring.yaml" \
    "$APP_DIR/k8s/ingress.yaml" \
    "$APP_DIR/observability/prometheus/prometheus.yml" \
    "$APP_DIR/observability/grafana/provisioning/datasources/prometheus.yml" \
    "$APP_DIR/observability/grafana/provisioning/dashboards/dashboards.yml" \
    "$APP_DIR/observability/grafana/dashboards/platform-lab.json"; do
    if [ -f "$file" ]; then
      verify_ok "${file#$APP_DIR/} exists"
    else
      verify_no "${file#$APP_DIR/} missing"
    fi
  done

  echo
  echo "== Image backups =="

  for file in \
    "$BACKUP_DIR/platform-engineering-lab-api.tar" \
    "$BACKUP_DIR/platform-engineering-lab-worker.tar"; do
    if [ -f "$file" ]; then
      verify_ok "$(basename "$file") exists"
    else
      verify_no "$(basename "$file") missing"
    fi
  done

  echo
  echo "== SSH readiness =="

  if [ -f /root/.ssh/id_ed25519 ]; then
    verify_ok "root SSH private key exists"
  else
    verify_no "root SSH private key missing"
  fi

  if [ -f /root/.ssh/id_ed25519.pub ]; then
    verify_ok "root SSH public key exists"
  else
    verify_no "root SSH public key missing"
  fi

  echo
  if [ "$VERIFY_FAILED" -eq 0 ]; then
    check_ok "verify passed"
    echo
    echo "Next: platformctl capacity"
    return 0
  fi

  check_no "verify failed"
  echo
  echo "Fix failed checks before running: platformctl build"
  return 1
}


shape_plan_summary() {
  local plan_file="$1"

  terraform show -json "$plan_file" 2>/dev/null | jq -r '
    def has_action($a): .change.actions | index($a) != null;
    {
      create: ([.resource_changes[]? | select(has_action("create"))] | length),
      update: ([.resource_changes[]? | select(has_action("update"))] | length),
      delete: ([.resource_changes[]? | select(has_action("delete"))] | length),
      replace: ([.resource_changes[]? | select((.change.actions | index("create") != null) and (.change.actions | index("delete") != null))] | length)
    }
    | "plan summary: create=\(.create), update=\(.update), delete=\(.delete), replace=\(.replace)"
  ' 2>/dev/null || echo "plan summary unavailable"
}

shape_check() {
  require_root
  require_cmds
  require_lab_files

  local workers="$1"
  local min_demo_workers=2
  local plan_file="/tmp/platformctl-shape-${workers}.tfplan"
  local log_file="/tmp/platformctl-shape-${workers}.log"
  local rc=0

  echo
  echo "== Platform shape check =="
  echo "Requested shape: 1 control + ${workers:-missing} workers"

  if ! printf '%s' "$workers" | grep -Eq '^[0-9]+$'; then
    check_no "worker count must be a non-negative integer"
    return 1
  fi

  if [ "$workers" -lt "$min_demo_workers" ]; then
    check_no "shape rejected: demo requires at least ${min_demo_workers} workers"
    echo
    echo "Reason:"
    echo "  The demo needs one Redis/PVC node and one separate worker node that can be safely drained."
    return 1
  fi

  check_ok "demo minimum satisfied: ${workers} workers"

  rm -f "$plan_file" "$log_file"

  echo
  echo "Running Terraform validation and capacity guardrail..."
  echo "No changes will be applied."

  terraform init -input=false >/dev/null
  terraform validate >/dev/null

  set +e
  terraform plan \
    -input=false \
    -detailed-exitcode \
    -var="worker_count=${workers}" \
    -out="$plan_file" >"$log_file" 2>&1
  rc="$?"
  set -e

  if [ "$rc" = "0" ]; then
    check_ok "shape accepted: already matches Terraform state"
    shape_plan_summary "$plan_file"
    echo
    check_ok "valid lab shape: 1 control + ${workers} workers"
    return 0
  fi

  if [ "$rc" = "2" ]; then
    check_ok "shape accepted: Terraform can converge to this shape"
    check_warn "shape differs from current Terraform state; no changes were applied"
    shape_plan_summary "$plan_file"
    echo
    check_ok "valid lab shape: 1 control + ${workers} workers"
    return 0
  fi

  check_no "shape rejected by Terraform validation or capacity guardrail"
  echo
  echo "Terraform/preflight output:"
  grep -E "Error:|capacity|memory|CPU|disk|VMID|requested|available|insufficient|exceeds|not enough|preflight" "$log_file" | head -80 || sed -n '1,120p' "$log_file"
  echo
  echo "Full log:"
  echo "  $log_file"
  return 1
}

shape() {
  local subcommand="${1:-}"
  local flag="${2:-}"
  local workers="${3:-}"

  case "$subcommand" in
    check)
      [ "$flag" = "--workers" ] || die "Use: platformctl shape check --workers <count>"
      [ -n "$workers" ] || die "Use: platformctl shape check --workers <count>"
      shape_check "$workers"
      ;;
    *)
      die "Unknown shape command. Use: platformctl shape check --workers <count>"
      ;;
  esac
}

capacity() {
  require_root
  require_cmds

  echo
  echo "== Host capacity =="

  local cpu_count
  local mem_total_mb
  local mem_available_mb
  local root_free
  local lab_free

  cpu_count="$(nproc)"
  mem_total_mb="$(free -m | awk '/^Mem:/ {print $2}')"
  mem_available_mb="$(free -m | awk '/^Mem:/ {print $7}')"
  root_free="$(df -h / | awk 'NR==2 {print $4}')"
  lab_free="$(df -h "$LAB_DIR" | awk 'NR==2 {print $4}')"

  check_ok "logical CPUs: ${cpu_count}"
  check_ok "memory total: ${mem_total_mb} MB"
  check_ok "memory available: ${mem_available_mb} MB"
  check_ok "root filesystem free: ${root_free}"
  check_ok "lab filesystem free: ${lab_free}"

  if [ "$cpu_count" -ge 6 ]; then
    check_ok "CPU capacity suitable for current lab"
  else
    check_warn "CPU capacity is tight for multi-node lab"
  fi

  if [ "$mem_available_mb" -ge 4096 ]; then
    check_ok "available memory suitable for current lab"
  else
    check_warn "available memory is tight"
  fi

  echo
  echo "== Proxmox storage =="

  if command -v pvesm >/dev/null 2>&1; then
    pvesm status || true
  else
    check_warn "pvesm command unavailable"
  fi

  echo
  echo "== Terraform lab footprint =="

  if terraform_has_lab_vms; then
    check_ok "Terraform lab VMs currently exist"
    terraform output || true
  else
    check_warn "Terraform lab VMs are not currently built"
  fi

  echo
  echo "== Kubernetes capacity =="

  if cluster_reachable; then
    kubectl get nodes -o wide || true

    local ready_workers
    ready_workers="$(kubectl get nodes --no-headers | awk '$2 == "Ready" && $3 !~ /control-plane|master/ {count++} END {print count + 0}')"

    if [ "$ready_workers" -gt 0 ]; then
      check_ok "ready worker nodes: ${ready_workers}"
      check_ok "safe demo app worker replicas: 1-$((ready_workers * 2))"
    else
      check_warn "no ready worker nodes found"
    fi

    echo
    echo "Current app deployment requests:"
    kubectl get deploy redis api worker prometheus grafana 2>/dev/null || true
  else
    check_warn "Kubernetes not reachable; cluster capacity unavailable"
  fi

  echo
  echo "Capacity note:"
  echo "  This lab is sized for platform demonstration, not production load testing."
}

build() {
  local mode="${1:-normal}"

  case "$mode" in
    normal|--resume|--force)
      ;;
    *)
      die "Unknown build option: $mode. Use: platformctl build, platformctl build --resume, or platformctl build --force"
      ;;
  esac

  if [ "$mode" = "--force" ]; then
    state_update "build-force" "running" "force build requested"
  fi

  run_phase "preflight" phase_preflight
  run_phase "terraform-apply" phase_terraform_apply
  run_phase "terraform-outputs" phase_outputs
  run_phase "ssh-ready" phase_ssh_ready
  run_phase "apt-ready" phase_apt_ready

  if cluster_reachable && [ "$mode" != "--force" ]; then
    echo
    echo "== k3s-bootstrap =="
    echo "Cluster already reachable; skipping bootstrap. Use 'platformctl build --force' to reinstall k3s."
    state_update "k3s-bootstrap" "success" "cluster already reachable"
  else
    run_phase "k3s-bootstrap" phase_k3s_bootstrap
  fi

  run_phase "nodes-ready" phase_nodes_ready

  echo
  echo "Build complete."
  echo "Cluster is ready. App is not deployed yet."
  echo
  echo "Next: platformctl deploy"
}

deploy() {
  require_root
  require_cmds
  require_lab_files
  require_app_files
  require_image_backups
  require_nodes_ready

  state_update "deploy" "running" ""

  set +e
  ./deploy-platform.sh
  local rc="$?"
  set -e

  if [ "$rc" -ne 0 ]; then
    state_update "deploy" "failed" "exit code ${rc}"
    die "Deploy failed. Run: platformctl status full"
  fi

  state_update "deploy" "success" ""

  echo
  echo "Deploy complete."
  echo "Next: platformctl smoke"
}

undeploy() {
  require_root
  require_cmds
  require_cluster

  confirm_exact "This removes app/monitoring workloads but keeps the VMs and k3s cluster."

  state_update "undeploy" "running" ""

  kubectl delete -f "$APP_DIR/k8s/monitoring.yaml" --ignore-not-found=true || true
  kubectl delete -f "$APP_DIR/k8s/worker.yaml" --ignore-not-found=true || true
  kubectl delete -f "$APP_DIR/k8s/api.yaml" --ignore-not-found=true || true
  kubectl delete -f "$APP_DIR/k8s/redis.yaml" --ignore-not-found=true || true

  kubectl delete configmap prometheus-config --ignore-not-found=true || true
  kubectl delete configmap grafana-datasources --ignore-not-found=true || true
  kubectl delete configmap grafana-dashboard-providers --ignore-not-found=true || true
  kubectl delete configmap grafana-dashboards --ignore-not-found=true || true

  state_update "undeploy" "success" ""

  echo
  echo "Undeploy complete. Cluster remains built."
}

