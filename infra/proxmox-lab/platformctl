scale() {
  require_root
  require_cmds
  require_platform

  local target="${1:-}"
  local replicas="${2:-}"

  [ "$target" = "workers" ] || die "Use: platformctl scale workers <replicas>"
  printf '%s' "$replicas" | grep -Eq '^[0-9]+$' || die "Replica count must be a non-negative integer."

  echo
  echo "== Scaling app workers =="
  echo "Setting deployment/worker replicas to ${replicas}"

  kubectl scale deployment/worker --replicas="$replicas"

  if [ "$replicas" != "0" ]; then
    kubectl rollout status deployment/worker --timeout=180s
  fi

  kubectl get deployment worker
  kubectl get pods -l app=worker -o wide || true

  echo
  echo "Scale complete."
}

status_short() {
  state_init

  local state_status
  local state_stage
  local last_success
  local last_failure
  local updated_at
  local control_ip
  local worker_ips

  state_status="$(jq -r '.status // "unknown"' "$STATE_FILE")"
  state_stage="$(jq -r '.stage // "unknown"' "$STATE_FILE")"
  last_success="$(jq -r '.last_success // ""' "$STATE_FILE")"
  last_failure="$(jq -r '.last_failure // ""' "$STATE_FILE")"
  updated_at="$(jq -r '.updated_at // ""' "$STATE_FILE")"

  echo
  echo "== Platform checklist =="

  if [ -n "$last_failure" ]; then
    check_warn "Last platformctl phase: ${state_stage} (${state_status}); last failure: ${last_failure}"
  elif [ -n "$last_success" ]; then
    check_ok "Last platformctl phase: ${last_success}"
  else
    check_warn "No completed platformctl phase recorded"
  fi

  [ -n "$updated_at" ] && check_ok "State file updated: ${updated_at}"

  echo
  echo "== Infrastructure =="

  if terraform_has_lab_vms; then
    check_ok "Terraform lab VMs exist"
  else
    check_no "Terraform lab VMs not built"
    echo
    echo "Next: platformctl build"
    return 0
  fi

  if control_ip="$(terraform output -raw control_ip 2>/dev/null)" && [ -n "$control_ip" ]; then
    check_ok "Terraform control output: ${control_ip}"
  else
    check_no "Terraform control output missing"
  fi

  if worker_ips="$(terraform output -json worker_ips 2>/dev/null | jq -r 'join(", ")')" && [ -n "$worker_ips" ]; then
    check_ok "Terraform worker outputs: ${worker_ips}"
  else
    check_no "Terraform worker outputs missing"
  fi

  if [ -f /root/.kube/config ]; then
    check_ok "kubeconfig exists"
  else
    check_no "kubeconfig missing"
  fi

  if cluster_reachable; then
    check_ok "Kubernetes API reachable"
  else
    check_no "Kubernetes API not reachable"
    echo
    echo "Next: platformctl build --resume"
    return 0
  fi

  nodes_ready_line

  echo
  echo "== Workloads =="

  if all_deployments_ready redis api worker; then
    check_ok "App deployments ready: redis, api, worker"
  else
    check_no "App deployments not fully ready"
    for deploy in redis api worker; do
      if deployment_ready "$deploy"; then
        check_ok "deployment/${deploy}"
      else
        check_no "deployment/${deploy}"
      fi
    done
  fi

  if all_deployments_ready prometheus grafana; then
    check_ok "Monitoring deployments ready: prometheus, grafana"
  else
    check_no "Monitoring deployments not fully ready"
    for deploy in prometheus grafana; do
      if deployment_ready "$deploy"; then
        check_ok "deployment/${deploy}"
      else
        check_no "deployment/${deploy}"
      fi
    done
  fi

  if all_services_exist redis api worker prometheus grafana; then
    check_ok "Services exist: redis, api, worker, prometheus, grafana"
  else
    check_no "One or more services missing"
    for svc in redis api worker prometheus grafana; do
      if service_exists "$svc"; then
        check_ok "service/${svc}"
      else
        check_no "service/${svc}"
      fi
    done
  fi

  echo
  echo "== Health =="

  api_health_line
  api_ingress_line
  redis_queue_line
  redis_persistence_line
  prometheus_targets_line

  echo
  echo "== Next =="
  if ! deployment_exists api; then
    echo "platformctl deploy"
  else
    echo "platformctl smoke"
    echo "platformctl capacity"
    echo "platformctl scale workers 3"
    echo "platformctl drill idempotency
platformctl drill drain-node"
    echo "platformctl drill all"
  fi
}

status_full() {
  status_short

  echo
  echo "== Raw state file =="
  state_show || true

  if ! terraform_has_lab_vms; then
    return 0
  fi

  echo
  echo "== Raw Terraform outputs =="
  terraform output || true

  if ! cluster_reachable; then
    return 0
  fi

  echo
  echo "== Raw nodes =="
  kubectl get nodes -o wide || true

  echo
  echo "== Raw pods =="
  kubectl get pods -o wide || true

  echo
  echo "== Raw deployments =="
  kubectl get deploy || true

  echo
  echo "== Raw services =="
  kubectl get svc || true

  echo
  echo "== Raw Redis queue length =="
  if kubectl get deployment redis >/dev/null 2>&1; then
    kubectl exec deploy/redis -- redis-cli LLEN "$QUEUE_NAME" || true
  else
    echo "redis deployment not found"
  fi

  echo
  echo "== Raw Prometheus targets =="
  if kubectl get service prometheus >/dev/null 2>&1 && ! ss -ltn | awk '{print $4}' | grep -Eq '[:.]19091$'; then
    kubectl port-forward service/prometheus 19091:9090 >/tmp/platformctl-prom-status.log 2>&1 &
    local prom_pf="$!"
    sleep 2
    curl -fsS "http://127.0.0.1:19091/api/v1/targets" \
      | jq '.data.activeTargets[]? | {job: .labels.job, health: .health, scrapeUrl: .scrapeUrl}' || true
    kill "$prom_pf" >/dev/null 2>&1 || true
    wait "$prom_pf" >/dev/null 2>&1 || true
  else
    echo "prometheus service missing or port 19091 busy"
  fi
}

status() {
  require_root
  require_cmds

  case "${1:-short}" in
    short)
      status_short
      ;;
    full)
      status_full
      ;;
    *)
      die "Unknown status mode: $1. Use: platformctl status or platformctl status full"
      ;;
  esac
}

diagnose_node_ssh() {
  local ip="$1"

  if ssh $(ssh_opts) "${SSH_USER}@${ip}" "true" >/dev/null 2>&1; then
    diagnose_ok "SSH reachable: ${ip}"
  else
    diagnose_no "SSH not reachable: ${ip}"
    return 0
  fi

  if ssh $(ssh_opts) "${SSH_USER}@${ip}" "sudo fuser /var/lib/dpkg/lock-frontend /var/lib/dpkg/lock /var/lib/apt/lists/lock /var/cache/apt/archives/lock >/dev/null 2>&1"; then
    diagnose_warn "apt/dpkg lock active: ${ip}"
  else
    diagnose_ok "apt/dpkg unlocked: ${ip}"
  fi

  if ssh $(ssh_opts) "${SSH_USER}@${ip}" "systemctl is-active --quiet k3s 2>/dev/null || systemctl is-active --quiet k3s-agent 2>/dev/null"; then
    diagnose_ok "k3s service active: ${ip}"
  else
    diagnose_warn "k3s service not active or not installed: ${ip}"
  fi
}

diagnose() {
  DIAGNOSE_FAILED=0

  echo
  echo "== Diagnosis: host =="

  if [ "$(id -u)" = "0" ]; then
    diagnose_ok "running as root"
  else
    diagnose_no "not running as root"
  fi

  if [ -f "$STATE_FILE" ]; then
    diagnose_ok "platform state file exists"
  else
    diagnose_warn "platform state file missing"
  fi

  if terraform validate >/dev/null 2>&1; then
    diagnose_ok "Terraform configuration validates"
  else
    diagnose_no "Terraform configuration validation failed"
  fi

  echo
  echo "== Diagnosis: Terraform =="

  if terraform_has_lab_vms; then
    diagnose_ok "Terraform lab VMs exist in state"
  else
    diagnose_warn "Terraform lab VMs not present in state"
    echo
    echo "Next: platformctl build"
    return 0
  fi

  try_load_outputs

  if [ -n "$CONTROL_IP" ]; then
    diagnose_ok "control IP output: ${CONTROL_IP}"
  else
    diagnose_no "control IP output missing"
  fi

  if [ "${#WORKER_IPS[@]}" -gt 0 ]; then
    diagnose_ok "worker IP outputs: ${WORKER_IPS[*]}"
  else
    diagnose_no "worker IP outputs missing"
  fi

  echo
  echo "== Diagnosis: Proxmox VMs =="

  if command -v qm >/dev/null 2>&1; then
    local vmid
    for vmid in $(terraform state show 'proxmox_virtual_environment_vm.lab["tf-k8s-control"]' 2>/dev/null | awk '$1 == "vm_id" && $2 == "=" {print $3; exit}' || true); do
      if qm status "$vmid" >/dev/null 2>&1; then
        diagnose_ok "control VM ${vmid}: $(qm status "$vmid" | awk '{print $2}')"
      else
        diagnose_no "control VM ${vmid} not found by qm"
      fi
    done
  else
    diagnose_warn "qm command missing"
  fi

  echo
  echo "== Diagnosis: SSH / apt / k3s services =="

  if [ -n "$CONTROL_IP" ]; then
    diagnose_node_ssh "$CONTROL_IP"
  fi

  for ip in "${WORKER_IPS[@]}"; do
    diagnose_node_ssh "$ip"
  done

  echo
  echo "== Diagnosis: Kubernetes =="

  if [ -f /root/.kube/config ]; then
    diagnose_ok "kubeconfig exists"
    local kube_server
    kube_server="$(grep 'server:' /root/.kube/config | head -1 | awk '{print $2}' || true)"
    [ -n "$kube_server" ] && diagnose_ok "kubeconfig server: ${kube_server}"
  else
    diagnose_warn "kubeconfig missing"
  fi

  if cluster_reachable; then
    diagnose_ok "Kubernetes API reachable"
    kubectl get nodes -o wide || true
  else
    diagnose_no "Kubernetes API not reachable"
    echo
    echo "Suggested next actions:"
    echo "  platformctl repair"
    echo "  platformctl build --resume"
    echo "  platformctl build --force"
    return "$DIAGNOSE_FAILED"
  fi

  echo
  echo "== Diagnosis: workloads =="

  for deploy in redis api worker prometheus grafana; do
    if deployment_ready "$deploy"; then
      diagnose_ok "deployment/${deploy} ready"
    elif deployment_exists "$deploy"; then
      diagnose_no "deployment/${deploy} exists but is not ready"
      kubectl describe deployment "$deploy" | sed -n '1,80p' || true
    else
      diagnose_warn "deployment/${deploy} missing"
    fi
  done

  echo
  echo "== Diagnosis: pods =="

  kubectl get pods -o wide || true

  local bad_pods
  bad_pods="$(kubectl get pods --no-headers 2>/dev/null | awk '$3 != "Running" && $3 != "Completed" {print $1}' || true)"

  if [ -n "$bad_pods" ]; then
    diagnose_no "non-running pods found: ${bad_pods}"
    for pod in $bad_pods; do
      echo
      echo "-- describe pod/${pod} --"
      kubectl describe pod "$pod" | sed -n '1,120p' || true
    done
  else
    diagnose_ok "no non-running pods found"
  fi

  echo
  echo "== Diagnosis: recent Kubernetes events =="

  kubectl get events --sort-by=.metadata.creationTimestamp | tail -30 || true

  echo
  echo "== Diagnosis: queue and monitoring =="

  redis_queue_line
  redis_persistence_line
  prometheus_targets_line

  echo
  if [ "$DIAGNOSE_FAILED" -eq 0 ]; then
    check_ok "diagnose completed without hard failures"
  else
    check_no "diagnose found failures"
  fi

  return "$DIAGNOSE_FAILED"
}


runtime_image_diagnostics() {
  local deploy="$1"

  echo
  echo "== Runtime image diagnostics: deployment/${deploy} =="
  kubectl get deployment "$deploy" -o wide || true
  kubectl get rs -l "app=${deploy}" -o wide || true
  kubectl get pods -l "app=${deploy}" -o wide || true

  echo
  echo "Recent related events:"
  kubectl get events --sort-by=.lastTimestamp \
    | grep -E "pod/${deploy}|deployment/${deploy}|replicaset/${deploy}|ImagePull|BackOff|ErrImagePull" \
    | tail -40 || true
}

deployment_runtime_ready() {
  local deploy="$1"
  local expected
  local rows
  local bad=0

  expected="$(kubectl get deployment "$deploy" -o jsonpath='{.spec.template.spec.containers[0].image}' 2>/dev/null || true)"

  if [ -z "$expected" ]; then
    check_no "deployment/${deploy} image could not be determined"
    runtime_image_diagnostics "$deploy"
    return 1
  fi

  echo
  echo "Checking deployment/${deploy} runtime image..."
  echo "Expected image: ${expected}"

  if ! kubectl rollout status "deployment/${deploy}" --timeout=60s; then
    check_no "deployment/${deploy} rollout is not complete"
    runtime_image_diagnostics "$deploy"
    return 1
  fi

  rows="$(
    kubectl get pods -l "app=${deploy}" -o json 2>/dev/null \
      | jq -r '.items[] | [
          .metadata.name,
          .spec.containers[0].image,
          (.status.containerStatuses[0].ready // false | tostring),
          (.status.containerStatuses[0].state.waiting.reason // "")
        ] | @tsv'
  )"

  if [ -z "$rows" ]; then
    check_no "deployment/${deploy} has no pods"
    runtime_image_diagnostics "$deploy"
    return 1
  fi

  while IFS=$'\t' read -r pod image ready waiting; do
    [ -n "$pod" ] || continue

    echo "  ${pod}: image=${image}, ready=${ready}, waiting=${waiting:-none}"

    if [ "$image" != "$expected" ] || [ "$ready" != "true" ] || [ -n "$waiting" ]; then
      bad=1
    fi
  done <<< "$rows"

  if [ "$bad" != "0" ]; then
    check_no "deployment/${deploy} pods do not match the expected ready runtime image"
    runtime_image_diagnostics "$deploy"
    return 1
  fi

  check_ok "deployment/${deploy} runtime image ready: ${expected}"
}

idempotency_drill() {
  require_root
  require_cmds
  require_platform

  local control_ip
  local node_port
  local idem
  local code1
  local code2
  local id1
  local id2

  echo
  echo "== Idempotency drill =="
  echo "This first verifies rollout/image state so old pods or ImagePullBackOff do not hide the real result."

  deployment_runtime_ready api || return 1
  deployment_runtime_ready worker || return 1

  if ! ingress_controller_ready || ! ingress_exists; then
    check_no "Ingress is not ready"
    echo "Run: platformctl deploy"
    return 1
  fi

  control_ip="$(terraform output -raw control_ip 2>/dev/null || true)"
  node_port="$(ingress_http_node_port || true)"

  if [ -z "$control_ip" ] || [ -z "$node_port" ] || [ "$node_port" = "null" ]; then
    check_no "Could not determine API ingress address"
    return 1
  fi

  idem="platformctl-idempotency-$(date +%s)"

  rm -f /tmp/platformctl-idempotency-headers-1.txt \
        /tmp/platformctl-idempotency-headers-2.txt \
        /tmp/platformctl-idempotency-body-1.json \
        /tmp/platformctl-idempotency-body-2.json

  echo
  echo "API route:"
  echo "  http://${control_ip}:${node_port}/events"
  echo "Idempotency-Key:"
  echo "  ${idem}"

  code1="$(
    curl -sS \
      -D /tmp/platformctl-idempotency-headers-1.txt \
      -o /tmp/platformctl-idempotency-body-1.json \
      -w '%{http_code}' \
      -H 'Host: platform.local' \
      -H "Idempotency-Key: ${idem}" \
      -X POST "http://${control_ip}:${node_port}/events" || true
  )"

  code2="$(
    curl -sS \
      -D /tmp/platformctl-idempotency-headers-2.txt \
      -o /tmp/platformctl-idempotency-body-2.json \
      -w '%{http_code}' \
      -H 'Host: platform.local' \
      -H "Idempotency-Key: ${idem}" \
      -X POST "http://${control_ip}:${node_port}/events" || true
  )"

  id1="$(jq -r '.id // empty' /tmp/platformctl-idempotency-body-1.json 2>/dev/null || true)"
  id2="$(jq -r '.id // empty' /tmp/platformctl-idempotency-body-2.json 2>/dev/null || true)"

  echo
  echo "First response:  HTTP ${code1}, id=${id1:-missing}"
  echo "Second response: HTTP ${code2}, id=${id2:-missing}"

  if grep -qi '^X-Idempotent-Replay:[[:space:]]*true' /tmp/platformctl-idempotency-headers-2.txt; then
    echo "Second response replay header: true"
  else
    echo "Second response replay header: missing"
  fi

  if [ "$code1" = "202" ] \
    && [ "$code2" = "200" ] \
    && [ -n "$id1" ] \
    && [ "$id1" = "$id2" ] \
    && grep -qi '^X-Idempotent-Replay:[[:space:]]*true' /tmp/platformctl-idempotency-headers-2.txt; then
    check_ok "Idempotency drill passed"
    return 0
  fi

  check_no "Idempotency drill failed"

  echo
  echo "First headers:"
  cat /tmp/platformctl-idempotency-headers-1.txt || true
  echo
  echo "First body:"
  cat /tmp/platformctl-idempotency-body-1.json || true
  echo
  echo "Second headers:"
  cat /tmp/platformctl-idempotency-headers-2.txt || true
  echo
  echo "Second body:"
  cat /tmp/platformctl-idempotency-body-2.json || true

  echo
  echo "API logs:"
  kubectl logs deploy/api --tail=80 || true

  return 1
}
drain_node_drill() {
  require_root
  require_cmds
  require_platform

  local redis_node=""
  local target_node=""
  local candidate=""
  local new_redis_node=""

  echo
  echo "== Drain node drill =="
  echo "This drill avoids the Redis node because Redis uses local-path PVC storage."

  redis_node="$(kubectl get pod -l app=redis -o jsonpath='{.items[0].spec.nodeName}' 2>/dev/null || true)"

  if [ -z "$redis_node" ]; then
    check_warn "Redis pod has no assigned node; skipping drain to avoid disrupting PVC-bound Redis."
    return 0
  fi

  echo "Redis PVC-bound pod is on: ${redis_node}"

  while read -r candidate; do
    [ -n "$candidate" ] || continue

    if [ "$candidate" != "$redis_node" ]; then
      target_node="$candidate"
      break
    fi
  done < <(
    kubectl get nodes --no-headers \
      | awk '$2 == "Ready" && $3 !~ /control-plane|master/ {print $1}'
  )

  if [ -z "$target_node" ]; then
    check_warn "No safe worker node to drain. Redis is on the only available worker node."
    return 0
  fi

  echo "Selected safe drain target: ${target_node}"

  trap 'kubectl uncordon "'"$target_node"'" >/dev/null 2>&1 || true' INT TERM EXIT

  echo
  echo "Draining node: ${target_node}"
  kubectl drain "$target_node" \
    --ignore-daemonsets \
    --delete-emptydir-data \
    --force \
    --timeout=120s

  echo
  echo "Pods after drain:"
  kubectl get pods -o wide

  echo
  echo "Waiting for stateless deployments to recover..."

  kubectl rollout status deployment/api --timeout=180s
  kubectl rollout status deployment/worker --timeout=180s
  kubectl rollout status deployment/prometheus --timeout=180s
  kubectl rollout status deployment/grafana --timeout=180s

  echo
  echo "Checking Redis remained available on its PVC node..."

  kubectl rollout status deployment/redis --timeout=60s

  new_redis_node="$(kubectl get pod -l app=redis -o jsonpath='{.items[0].spec.nodeName}' 2>/dev/null || true)"

  if [ "$new_redis_node" = "$redis_node" ]; then
    check_ok "Redis stayed on PVC node: ${redis_node}"
  else
    check_no "Redis moved or became unscheduled; expected ${redis_node}, got ${new_redis_node:-none}"
    return 1
  fi

  echo
  echo "Uncordoning node: ${target_node}"
  kubectl uncordon "$target_node"

  trap - INT TERM EXIT

  check_ok "Drain node drill completed without disrupting Redis local-path PVC"
}
drill() {
  require_root
  require_cmds
  require_platform

  local drill_name="${1:-}"

  case "$drill_name" in
    idempotency)
      idempotency_drill
      return 0
      ;;
    redis-persistence)
      redis_persistence_drill
      return 0
      ;;
    drain-node)
      drain_node_drill
      return 0
      ;;
    status|smoke|kill-api|kill-worker|backlog|redis-persistence|all)
      ;;
    kill-redis)
      confirm_exact "This deletes the Redis pod. This demo Redis has no persistent volume, so queued data may be lost."
      ;;
    *)
      die "Unknown drill: ${drill_name}. Use: status, smoke, kill-api, kill-worker, kill-redis, backlog, idempotency, redis-persistence, drain-node, all"
      ;;
  esac

  if [ "$drill_name" = "backlog" ] || [ "$drill_name" = "all" ]; then
    trap 'kubectl scale deployment/worker --replicas=1 >/dev/null 2>&1 || true' EXIT
  fi

  ./drill-platform.sh "$drill_name"
}

repair() {
  require_root
  require_cmds
  require_lab_files

  if ! terraform_has_lab_vms; then
    echo "Platform not built. Nothing to repair."
    echo
    echo "Next: platformctl build"
    return 0
  fi

  state_update "repair" "running" ""

  load_outputs
  phase_ssh_ready
  phase_apt_ready

  echo
  echo "Restarting k3s services where present..."

  ssh $(ssh_opts) "${SSH_USER}@${CONTROL_IP}" "sudo systemctl restart k3s 2>/dev/null || true"

  for ip in "${WORKER_IPS[@]}"; do
    ssh $(ssh_opts) "${SSH_USER}@${ip}" "sudo systemctl restart k3s-agent 2>/dev/null || true"
  done

  echo
  echo "Refreshing kubeconfig if available..."

  mkdir -p /root/.kube

  if ssh $(ssh_opts) "${SSH_USER}@${CONTROL_IP}" "test -f /etc/rancher/k3s/k3s.yaml"; then
    ssh $(ssh_opts) "${SSH_USER}@${CONTROL_IP}" "sudo cat /etc/rancher/k3s/k3s.yaml" \
      | sed "s/127.0.0.1/${CONTROL_IP}/g" > /root/.kube/config
  fi

  if cluster_reachable; then
    kubectl wait --for=condition=Ready nodes --all --timeout=180s || true
    kubectl get nodes -o wide || true
    state_update "repair" "success" ""
    echo
    echo "Repair complete."
  else
    state_update "repair" "failed" "cluster still unreachable"
    die "Repair could not reach Kubernetes. Try: platformctl build --force"
  fi
}

destroy() {
  require_root
  require_cmds
  require_lab_files

  confirm_exact "This will destroy the Terraform-managed k3s VMs."

  state_update "destroy" "running" ""

  terraform destroy -auto-approve

  rm -f /root/.kube/config

  state_update "destroy" "success" "Terraform-managed VMs destroyed"

  echo
  echo "Destroy complete."
}

